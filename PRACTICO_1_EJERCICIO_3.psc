Algoritmo PromedioNotas
	
    Definir n1, n2, n3, promedio Como Real
	
    Escribir "Ingrese nota 1:"
    Leer n1
	
    Escribir "Ingrese nota 2:"
    Leer n2
	
    Escribir "Ingrese nota 3:"
    Leer n3
	
    promedio <- (n1 + n2 + n3) / 3
	
    Escribir "El promedio es: ", promedio
	
FinAlgoritmo